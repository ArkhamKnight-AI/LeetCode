class Solution {
public:
    ListNode* merge(ListNode* l1, ListNode* l2) {
    //哨兵节点
    auto dummy = new ListNode(-1);

    auto cur = dummy;

    //当两个链表不为空时
    while (l1 && l2) {
        if (l1->val <= l2->val) {
            cur->next = l1;
            cur = l1;
            l1 = l1->next;
        }
        else {
            cur->next = l2;
            cur = l2;
            l2 = l2->next;
        }
    }

    if(l1) cur->next = l1;
    else cur->next = l2;

    return dummy->next;
}
};
