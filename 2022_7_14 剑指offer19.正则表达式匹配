class Solution {
public:
     vector<vector<int>>f;
    int n, m;
    bool isMatch(string s, string p) {
        n = s.size();
        m = p.size();
        f = vector<vector<int>>(n + 1, vector<int>(m + 1, -1));
        return dp(0, 0, s, p);
    }

    bool dp(int x, int y, string &s, string &p)
    {
        //如果不为-1 直接返回x,y位置的数
        if(f[x][y] != -1) return f[x][y];
        
        //只有全部为空串时才会匹配成功
        if(y == m){
            return f[x][y] = x == n;
        }
        
        //第一个元素是否匹配
        bool first_match = x < n && y < m && (s[x] == p[y] || s[x] == '.' || p[y] == '.');
        
        //p + 1位置为 ‘*’
        if(y + 1 < m && p[y + 1] == '*'){
            f[x][y] = dp(x, y + 2, s, p) || (first_match && dp(x + 1, y, s, p));
        }
        
        else{
            f[x][y] = first_match && dp(x + 1, y + 1, s, p);
        }
        
        return f[x][y];
    }


};
